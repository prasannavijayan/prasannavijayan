---
import "@pv/tokens/tokens.css";
import "@pv/ui/ui.css";
import { Footer } from "@pv/ui";
// `?url` → resolve to a URL string. Astro 5 otherwise imports SVGs as components.
import faviconLight from "@pv/logos/pvy-blog-light.svg?url";
import faviconDark from "@pv/logos/pvy-blog-dark.svg?url";

interface Props {
  title: string;
  description?: string;
  // When rendering a single post, expose it to the dev Review Timer toolbar app.
  postSlug?: string;
  postStatus?: string;
}
const { title, description, postSlug, postStatus } = Astro.props;
const brandLogo = faviconLight;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href={faviconLight} media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/svg+xml" href={faviconDark} media="(prefers-color-scheme: dark)" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Google+Sans:wght@400;500;600&family=Google+Sans+Text:wght@400;500&family=Roboto:wght@300;400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body data-post-slug={postSlug} data-post-status={postStatus}>
    <header class="topnav">
      <a class="brand" href="https://prasannavijayan.in">
        <img class="brand-logo" src={brandLogo} alt="Pvy" />
        <span class="brand-text">Prasanna <span>Vijayan</span></span>
      </a>
      <a class="chip" href="/">Blog</a>
    </header>

    <slot />

    <Footer name="Prasanna Vijayan" logoSrc={brandLogo} />

    <style>
      :global(*) { box-sizing: border-box; margin: 0; padding: 0; }
      :global(body) {
        font-family: "Roboto", "Google Sans Text", sans-serif;
        background: var(--bg);
        color: var(--text-primary);
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      .topnav {
        display: flex;
        align-items: center;
        gap: 12px;
        height: 64px;
        padding: 0 20px;
        border-bottom: 1px solid var(--border);
      }
      .brand {
        display: flex;
        align-items: center;
        gap: 10px;
        text-decoration: none;
      }
      .brand-logo {
        width: 28px;
        height: 28px;
        border-radius: 50%;
        display: block;
      }
      .brand-text {
        font-family: "Google Sans", sans-serif;
        font-size: 18px;
        font-weight: 500;
        color: var(--text-primary);
      }
      .brand-text span { color: var(--accent); }
      .chip {
        font-size: 11px;
        color: var(--text-secondary);
        background: var(--bg-tertiary);
        padding: 4px 10px;
        border-radius: 20px;
        text-decoration: none;
      }
    </style>
  </body>
</html>
