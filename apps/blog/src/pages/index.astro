---
import { getCollection } from "astro:content";
import BlogLayout from "@/layouts/BlogLayout.astro";
import Provenance from "@/components/Provenance.astro";
import { formatDate, isVisible } from "@/lib/provenance";

// In dev: all posts (draft reading mode). In production: only published. Newest first.
const allPosts = (await getCollection("blog", (p) => isVisible(p.data.status))).sort(
  (a, b) =>
    new Date(b.data.publishedAt || b.data.created).getTime() -
    new Date(a.data.publishedAt || a.data.created).getTime(),
);

const pinned = allPosts.find((p) => p.data.pinned);
const posts = allPosts.filter((p) => !p.data.pinned);

function readingTime(body: string): number {
  const words = body.split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}
---

<BlogLayout title="Prasanna Vijayan — Blog" description="Notes on JavaScript, frontend, and building for the web.">
  <main class="transition-slide index-layout">
    {pinned && <div class="rail-spacer" aria-hidden="true" />}

    <div class="post-column">
      <h1>Writing</h1>
      {
        posts.length === 0 ? (
          <p class="empty">No posts yet — coming soon.</p>
        ) : (
          <ul class="post-list">
            {posts.map((p) => (
              <li>
                <a href={`/${p.id}`}>
                  <span class="post-title">
                    {p.data.status !== "published" && <span class="draft-flag">Draft</span>}
                    {p.data.title}
                  </span>
                  <span class="post-meta">
                    {formatDate(p.data.publishedAt || p.data.created)} · {readingTime(p.body ?? "")} min read
                  </span>
                  <span class="post-excerpt">{p.data.description}</span>
                  <span class="post-footer-row">
                    <Provenance attribution={p.data.attribution} reviewTook={p.data.reviewTook} timeToPublish={p.data.timeToPublish} />
                  </span>
                </a>
              </li>
            ))}
          </ul>
        )
      }
    </div>

    {
      pinned && (
        <aside class="pinned-rail">
          <svg class="pinned-pin" width="200" height="200" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s7-7.6 7-12A7 7 0 0 0 5 10c0 4.4 7 12 7 12z" />
            <circle cx="12" cy="10" r="2.5" />
          </svg>
          <span class="pinned-label">Pinned</span>
          <a href={`/${pinned.id}`}>
            <span class="pinned-title">{pinned.data.title}</span>
            <span class="pinned-excerpt">{pinned.data.description}</span>
            <span class="pinned-footer">
              <Provenance
                attribution={pinned.data.attribution}
                reviewTook={pinned.data.reviewTook}
                timeToPublish={pinned.data.timeToPublish}
              />
            </span>
          </a>
        </aside>
      )
    }
  </main>

  <style>
    /* post-column (720) sits between a spacer and the aside (both 280 + 32 gap) so it
       stays centered on the page — matching how the article is centered on the
       single-post page — instead of the aside pulling it off-center.
       The aside and spacer live inside <main> (not as siblings) because swup's
       default `containers: ['main']` only swaps <main> between page loads —
       anything outside it survives navigation. */
    .index-layout {
      display: flex;
      align-items: flex-start;
      gap: 32px;
      max-width: 1344px;
      margin: 0 auto;
    }
    .rail-spacer {
      flex: 0 0 280px;
    }
    .post-column {
      flex: 1 1 auto;
      width: 100%;
      max-width: 720px;
      padding: 48px 20px;
    }
    .pinned-rail {
      position: sticky;
      flex: 0 0 280px;
      top: 24px;
      align-self: flex-start;
      margin-top: 116px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 18px;
      overflow: hidden;
    }
    .pinned-pin {
      position: absolute;
      bottom: -70px;
      right: -70px;
      color: var(--accent-text);
      opacity: 0.2;
    }
    .pinned-rail a {
      display: block;
      text-decoration: none;
      color: inherit;
    }
    .pinned-label {
      display: inline-block;
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--accent-text);
      background: var(--accent-light);
      padding: 2px 8px;
      border-radius: 20px;
      margin-bottom: 10px;
    }
    .pinned-title {
      display: block;
      font-family: "Google Sans", sans-serif;
      font-weight: 500;
      font-size: 15px;
      margin-bottom: 8px;
    }
    .pinned-excerpt {
      display: block;
      font-size: 13px;
      color: var(--text-secondary);
      line-height: 1.5;
      margin-bottom: 12px;
    }
    .pinned-footer {
      display: block;
    }
    @media (max-width: 1344px) {
      .index-layout {
        flex-direction: column;
        gap: 0;
      }
      .rail-spacer {
        display: none;
      }
      .pinned-rail {
        position: relative;
        /* flex-basis (280px, meant for width in the row layout above) would
           otherwise apply to height once the container switches to a column.
           align-self: stretch (rather than a 100% width, which ignores its
           own horizontal margins and overflows the viewport) sizes it to the
           container width minus the margins below. */
        flex: 0 0 auto;
        align-self: stretch;
        order: -1;
        margin: 32px 20px 0;
        overflow: hidden;
      }
    }
    h1 {
      font-family: "Google Sans", sans-serif;
      font-size: 30px;
      font-weight: 500;
      margin-bottom: 24px;
    }
    .empty { color: var(--text-secondary); }
    .post-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
    .post-list a {
      display: block;
      padding: 20px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      text-decoration: none;
      color: inherit;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .post-list a:hover { border-color: var(--accent); box-shadow: var(--shadow-md); }
    .post-title { display: block; font-family: "Google Sans", sans-serif; font-weight: 500; font-size: 17px; }
    .draft-flag {
      display: inline-block;
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: #b26a00;
      background: #fff3e0;
      border: 1px solid #ffcc80;
      padding: 1px 7px;
      border-radius: 20px;
      vertical-align: middle;
      margin-right: 8px;
    }
    .post-meta { display: block; font-size: 12px; color: var(--text-tertiary); margin: 4px 0 8px; }
    .post-excerpt { display: block; font-size: 14px; color: var(--text-secondary); line-height: 1.6; }
    .post-footer-row { display: block; margin-top: 12px; }
  </style>
</BlogLayout>
