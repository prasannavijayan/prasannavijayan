---
import { getCollection } from "astro:content";
import BlogLayout from "@/layouts/BlogLayout.astro";
import BlogPostList, { type PostSummary } from "@/components/BlogPostList";
import { formatDate, isVisible } from "@/lib/provenance";

// In dev: all posts (draft reading mode). In production: only published. Newest first.
const allPosts = (await getCollection("blog", (p) => isVisible(p.data.status))).sort(
  (a, b) =>
    new Date(b.data.publishedAt || b.data.created).getTime() -
    new Date(a.data.publishedAt || a.data.created).getTime(),
);

function readingTime(body: string): number {
  const words = body.split(/\s+/).filter(Boolean).length;
  return Math.max(1, Math.round(words / 200));
}

const posts: PostSummary[] = allPosts.map((p) => ({
  id: p.id,
  title: p.data.title,
  description: p.data.description,
  status: p.data.status,
  dateLabel: formatDate(p.data.publishedAt || p.data.created),
  readingTime: readingTime(p.body ?? ""),
  pinned: p.data.pinned,
  attribution: p.data.attribution,
  reviewTook: p.data.reviewTook,
  timeToPublish: p.data.timeToPublish,
  tags: p.data.tags,
}));
---

<BlogLayout title="Prasanna Vijayan — Blog" description="Notes on JavaScript, frontend, and building for the web.">
  <main class="transition-slide index-layout">
    <BlogPostList client:load posts={posts} />
  </main>

  <style is:global>
    /* Crossfade duration for the View Transition triggered from
       BlogPostList.tsx on a tag click (Writing <-> tag-filtered view) —
       short and subtle rather than the browser's default ~0.25s. */
    ::view-transition-old(root),
    ::view-transition-new(root) {
      animation-duration: 0.18s;
    }
    /* post-column (720) sits between the search panel and the aside (both 280 +
       32 gap) so it stays centered on the page — matching how the article is
       centered on the single-post page — instead of the aside pulling it
       off-center. Both live inside <main> (not as siblings) because swup's
       default `containers: ['main']` only swaps <main> between page loads —
       anything outside it survives navigation. This whole listing is rendered
       by the <BlogPostList> React island (is:global above lets these rules,
       written once in this .astro file, still reach elements it renders —
       Astro's CSS scoping only reaches the file's own template). */
    .index-layout {
      display: flex;
      flex: 1;
      align-items: flex-start;
      gap: 32px;
      width: 100%;
      max-width: 1344px;
      margin: 0 auto;
    }
    /* margin-top matches .pinned-rail below so the search box lines up with
       where the blog list itself starts, not the top of the page. */
    .search-panel {
      flex: 0 0 280px;
      position: sticky;
      top: 24px;
      align-self: flex-start;
      margin-top: 116px;
    }
    .search-input {
      width: 100%;
      font: inherit;
      font-size: 14px;
      color: var(--text-primary);
      background: var(--bg-secondary);
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 10px 14px;
    }
    .search-input:focus {
      outline: none;
      border-color: var(--accent);
      box-shadow: var(--shadow-md);
    }
    /* Desktop-only dropdown (hidden on mobile below) — a simple list of
       titles under the search box; Pinned/Writing stay untouched behind it.
       Clicking a title is a plain navigation to the post, full screen. */
    .search-dropdown {
      margin-top: 10px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      background: var(--bg-secondary);
      overflow: hidden;
    }
    .search-dropdown-status {
      padding: 10px 12px;
      font-size: 12px;
      color: var(--text-tertiary);
      line-height: 1.5;
    }
    .search-dropdown-status code {
      font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
      background: var(--bg-tertiary);
      padding: 1px 5px;
      border-radius: 4px;
    }
    .search-dropdown-list { list-style: none; }
    .search-dropdown-list li + li { border-top: 1px solid var(--border); }
    .search-dropdown-list a {
      display: block;
      padding: 10px 12px;
      font-size: 13px;
      color: inherit;
      text-decoration: none;
    }
    .search-dropdown-list a:hover { background: var(--bg-tertiary); }
    .no-results {
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      color: var(--text-tertiary);
      padding: 40px 20px;
    }
    .no-results-icon {
      width: 40px;
      height: 40px;
      margin-bottom: 14px;
      color: var(--text-tertiary);
      opacity: 0.6;
    }
    .no-results-text {
      font-family: "Google Sans", sans-serif;
      font-size: 15px;
      font-weight: 500;
      color: var(--text-secondary);
    }
    .no-results-subtext {
      font-size: 13px;
      margin-top: 4px;
    }
    /* Compact variant for the narrow desktop dropdown — smaller icon, no
       subtext, tighter padding. */
    .no-results-compact {
      padding: 20px 12px;
    }
    .no-results-compact .no-results-icon {
      width: 26px;
      height: 26px;
      margin-bottom: 8px;
    }
    .no-results-compact .no-results-text {
      font-size: 12px;
      font-weight: 400;
      color: var(--text-tertiary);
    }
    /* Fills the space below the search input by default. Default look
       matches .tag on the single-post page ([slug].astro); the active
       (aria-pressed) look matches the soft-accent pill already used by
       .pinned-label/.provenance-badge elsewhere on this page. */
    .tag-cloud {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
      margin-top: 14px;
    }
    .tag-chip {
      font: inherit;
      font-size: 11px;
      color: var(--text-secondary);
      background: var(--bg-tertiary);
      border: 1px solid transparent;
      padding: 4px 11px;
      border-radius: 20px;
      cursor: pointer;
      transition: background 0.15s, border-color 0.15s, color 0.15s;
    }
    .tag-chip:hover { border-color: var(--border); }
    .tag-chip[aria-pressed="true"] {
      color: var(--accent-text);
      background: var(--accent-light);
      border-color: var(--accent);
    }
    .post-column {
      flex: 1 1 auto;
      width: 100%;
      max-width: 720px;
      padding: 48px 20px;
    }
    /* Mobile-only full takeover of .post-column (hidden on desktop below —
       desktop keeps Writing showing and uses the dropdown above instead). */
    .mobile-search-results { display: none; }
    /* Tag-filter takeover — unlike the mobile-only search takeover above,
       this is NOT media-query-gated: a tag click is a discrete action (not
       live-typing), so it hides Writing on every viewport. Pinned stays
       visible throughout — it's excluded from the tag cloud/filter itself
       (it's a curated highlight, not part of the searchable set) but the
       card is a persistent fixture, not something filtering should hide. */
    .tag-filtered-results { display: none; }
    .post-column[data-tag-active] .tag-filtered-results { display: block; }
    .post-column[data-tag-active] .default-listing { display: none; }
    .pinned-rail {
      position: sticky;
      flex: 0 0 280px;
      top: 24px;
      align-self: flex-start;
      margin-top: 116px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      padding: 18px;
      overflow: hidden;
    }
    .pinned-pin {
      position: absolute;
      bottom: -70px;
      right: -70px;
      color: var(--accent-text);
      opacity: 0.2;
    }
    .pinned-rail a {
      display: block;
      text-decoration: none;
      color: inherit;
    }
    .pinned-label {
      display: inline-block;
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--accent-text);
      background: var(--accent-light);
      padding: 2px 8px;
      border-radius: 20px;
      margin-bottom: 10px;
    }
    .pinned-title {
      display: block;
      font-family: "Google Sans", sans-serif;
      font-weight: 500;
      font-size: 15px;
      margin-bottom: 8px;
    }
    .pinned-excerpt {
      display: block;
      font-size: 13px;
      color: var(--text-secondary);
      line-height: 1.5;
      margin-bottom: 12px;
    }
    .pinned-footer {
      display: block;
    }
    @media (max-width: 1344px) {
      .index-layout {
        flex-direction: column;
        gap: 0;
      }
      .search-panel {
        position: relative;
        top: auto;
        flex: 0 0 auto;
        align-self: stretch;
        order: -2;
        margin: 32px 20px 0;
      }
      /* The 720px cap is sized for the 3-column row layout (280 + gap + 720 +
         gap + 280 = 1344) — in the stacked column layout it has no reason to
         be narrower than .search-panel/.pinned-rail, whose own width just
         comes from stretching minus their 20px side margins. Without this,
         post cards fall short of the search box/pinned card's width below
         ~1344px, and the gap grows the narrower the viewport gets. */
      .post-column {
        max-width: none;
      }
      /* Mobile search is a full takeover, not the desktop dropdown: hide it
         here, and — while actively searching — hide Writing and Pinned so
         only the matched posts show (data-searching is set on .post-column
         by BlogPostList; ~ reaches .pinned-rail since it's a later sibling). */
      .search-dropdown {
        display: none;
      }
      .post-column[data-searching] .mobile-search-results {
        display: block;
      }
      .post-column[data-searching] .default-listing {
        display: none;
      }
      .post-column[data-searching] ~ .pinned-rail {
        display: none;
      }
      .pinned-rail {
        position: relative;
        /* flex-basis (280px, meant for width in the row layout above) would
           otherwise apply to height once the container switches to a column.
           align-self: stretch (rather than a 100% width, which ignores its
           own horizontal margins and overflows the viewport) sizes it to the
           container width minus the margins below. */
        flex: 0 0 auto;
        align-self: stretch;
        order: -1;
        margin: 32px 20px 0;
        overflow: hidden;
      }
    }
    h1 {
      font-family: "Google Sans", sans-serif;
      font-size: 30px;
      font-weight: 500;
      margin-bottom: 24px;
    }
    .empty { color: var(--text-secondary); }
    .post-list { list-style: none; display: flex; flex-direction: column; gap: 12px; }
    .post-list a {
      display: block;
      padding: 20px;
      border: 1px solid var(--border);
      border-radius: var(--radius-sm);
      text-decoration: none;
      color: inherit;
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    .post-list a:hover { border-color: var(--accent); box-shadow: var(--shadow-md); }
    .post-title { display: block; font-family: "Google Sans", sans-serif; font-weight: 500; font-size: 17px; }
    .draft-flag {
      display: inline-block;
      font-size: 10px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: #b26a00;
      background: #fff3e0;
      border: 1px solid #ffcc80;
      padding: 1px 7px;
      border-radius: 20px;
      vertical-align: middle;
      margin-right: 8px;
    }
    .post-meta { display: block; font-size: 12px; color: var(--text-tertiary); margin: 4px 0 8px; }
    .post-excerpt { display: block; font-size: 14px; color: var(--text-secondary); line-height: 1.6; }
    .post-footer-row { display: block; margin-top: 12px; }
  </style>
</BlogLayout>
