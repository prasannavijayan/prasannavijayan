---
// Provenance badge — shows authorship attribution and (once published) how long
// the human review took. Part of the future `astro-provenance` package.
interface Props {
  attribution: string;
  reviewTook?: string;
}
const { attribution, reviewTook } = Astro.props;
---

<span class="provenance">
  <span class="provenance-badge">{attribution}</span>
  {reviewTook && <span class="provenance-took">reviewed in {reviewTook}</span>}
</span>

<style>
  .provenance {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .provenance-badge {
    font-size: 11px;
    font-weight: 500;
    color: var(--accent-text);
    background: var(--accent-light);
    border: 1px solid var(--border);
    padding: 3px 10px;
    border-radius: 20px;
    font-family: "Google Sans Text", sans-serif;
  }
  .provenance-took {
    font-size: 11px;
    color: var(--text-tertiary);
    font-family: "Google Sans Text", sans-serif;
  }
</style>
