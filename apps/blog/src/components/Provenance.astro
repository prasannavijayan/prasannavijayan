---
// Provenance badge — authorship attribution + how the timing was measured.
// Prefers the actual review time (reviewTook); falls back to time-to-publish.
interface Props {
  attribution: string;
  reviewTook?: string;
  timeToPublish?: string;
}
const { attribution, reviewTook, timeToPublish } = Astro.props;

const timing = reviewTook
  ? `reviewed in ${reviewTook}`
  : timeToPublish
    ? `published ${timeToPublish} after drafting`
    : "";
---

<span class="provenance">
  {attribution && <span class="provenance-badge">{attribution}</span>}
  {reviewTook && (
    <svg
      class="verified-tick"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="var(--accent)"
      role="img"
    >
      <title>Timed review completed</title>
      <circle cx="12" cy="12" r="12" />
      <path
        d="M7 12.5l3 3 7-7"
        fill="none"
        stroke="var(--bg)"
        stroke-width="2.2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  )}
  {timing && <span class="provenance-took">{timing}</span>}
</span>

<!-- .provenance* rules live in global.css, not a scoped <style> here — this
     badge is also reimplemented in plain JSX as ProvenanceBadge in
     BlogPostList.tsx (the index page's React search island). Astro only
     bundles a component's CSS into pages that actually import that
     component, and index.astro no longer imports this one; global.css is
     loaded on every page via BlogLayout, so both usages pick up the rules. -->
