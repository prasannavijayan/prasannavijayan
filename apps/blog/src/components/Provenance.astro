---
// Provenance badge — authorship attribution + how the timing was measured.
// Prefers the actual review time (reviewTook); falls back to time-to-publish.
interface Props {
  attribution: string;
  reviewTook?: string;
  timeToPublish?: string;
}
const { attribution, reviewTook, timeToPublish } = Astro.props;

const timing = reviewTook
  ? `reviewed in ${reviewTook}`
  : timeToPublish
    ? `published ${timeToPublish} after drafting`
    : "";
---

<span class="provenance">
  {attribution && <span class="provenance-badge">{attribution}</span>}
  {reviewTook && (
    <svg
      class="verified-tick"
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="var(--accent)"
      role="img"
    >
      <title>Timed review completed</title>
      <circle cx="12" cy="12" r="12" />
      <path
        d="M7 12.5l3 3 7-7"
        fill="none"
        stroke="var(--bg)"
        stroke-width="2.2"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  )}
  {timing && <span class="provenance-took">{timing}</span>}
</span>

<style>
  .provenance {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
  }
  .provenance-badge {
    font-size: 11px;
    font-weight: 500;
    color: var(--accent-text);
    background: var(--accent-light);
    border: 1px solid var(--border);
    padding: 3px 10px;
    border-radius: 20px;
    font-family: "Google Sans Text", sans-serif;
  }
  .verified-tick {
    flex-shrink: 0;
  }
  .provenance-took {
    font-size: 11px;
    color: var(--text-tertiary);
    font-family: "Google Sans Text", sans-serif;
  }
</style>
