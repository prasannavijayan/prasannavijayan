{
  "name": "prasannavijayan-web",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for prasannavijayan.in — portfolio, blog, and zip, sharing one design system.",
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev:portfolio": "pnpm --filter portfolio dev",
    "dev:blog": "pnpm --filter blog dev",
    "dev:zip": "pnpm --filter zipgame dev",
    "build": "pnpm -r build",
    "prepare": "git config core.hooksPath .githooks || true"
  }
}
